<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f172a"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <!-- Game Title Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="KELİME SAVAŞI"
        android:textColor="#f8fafc"
        android:textSize="36sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:gravity="center" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kelime dağarcığını yarıştır, zirveye yerleş!"
        android:textColor="#94a3b8"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="64dp" />

    <!-- Guest Entry Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1e293b"
        android:padding="20dp"
        android:elevation="4dp"
        android:layout_marginHorizontal="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hızlı Başlangıç"
            android:textColor="#f1f5f9"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hesap oluşturmadan anında misafir olarak giriş yapabilir ve kelime yarışlarına katılabilirsiniz."
            android:textColor="#94a3b8"
            android:textSize="12sp"
            android:layout_marginBottom="24dp" />

        <!-- Play as Guest Button -->
        <Button
            android:id="@+id/btn_guest_login"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="MİSAFİR OLARAK OYNA"
            android:textColor="#ffffff"
            android:backgroundTint="#3b82f6"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

    </LinearLayout>

    <!-- Optional Footer Info -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tüm verileriniz ve başarılarınız güvenle saklanır."
        android:textColor="#64748b"
        android:textSize="12sp"
        android:layout_marginTop="48dp"
        android:gravity="center" />

</LinearLayout>
